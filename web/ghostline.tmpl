import asyncio
import json
import platform
import sys
from pathlib import Path

print("""
Ghostline web runtime
Pygbag {{cookiecutter.version}} // Python {{cookiecutter.PYBUILD}}
Loading {{cookiecutter.archive}}.tar.gz
""")


async def custom_site():
    import embed

    while str(platform.window.eval("typeof globalThis.ghostlineShell")) == "undefined":
        await asyncio.sleep(0.01)
    platform.document.body.style.background = "#000000"
    platform.window.canvas.style.visibility = "visible"
    platform.window.ghostlineShell.setBootState("booting", "Mounting the deterministic simulation...")

    bundle = "{{cookiecutter.archive}}"
    appdir = Path(f"/data/data/{bundle}")
    appdir.mkdir(exist_ok=True)

    if platform.window.location.host.find(".itch.zone") > 0:
        import zipfile
        async with platform.fopen("{{cookiecutter.archive}}.apk", "rb") as archive:
            with zipfile.ZipFile(archive) as compressed:
                compressed.extractall(appdir.as_posix())
    else:
        import tarfile
        async with platform.fopen("{{cookiecutter.archive}}.tar.gz", "rb") as archive:
            compressed = tarfile.open(fileobj=archive, mode="r:gz")
            compressed.extractall(path=appdir.as_posix(), filter="tar")
            compressed.close()

    platform.run_main(PyConfig, loaderhome=appdir / "assets", loadermain=None)
    while embed.counter() < 0:
        await asyncio.sleep(0.1)

    main = appdir / "assets" / "main.py"
    autoplay = str(platform.window.location.search).find("autoplay=1") >= 0
    if not platform.window.MM.UME and not autoplay:
        __import__(__name__).__file__ = main
        platform.window.ghostlineShell.setBootState("engage", "One click unlocks audio and keyboard control.")
        while not platform.window.MM.UME:
            await asyncio.sleep(0.1)

    await TopLevel_async_handler.start_toplevel(platform.shell, console=window.python.config.debug)
    __import__(__name__).__file__ = main

    def package_progress(package):
        platform.window.ghostlineShell.setBootState("booting", f"Installing browser package: {package}")

    await shell.source(main, callback=package_progress)
    platform.window.transfer.hidden = true
    platform.window.infobox.style.display = "none"
    platform.window.config.gui_divider = 1
    platform.window.window_resize()
    shell.interactive()


asyncio.run(custom_site())

